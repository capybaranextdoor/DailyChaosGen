{
  "entities": {
    "users": {
      "title": "User Profile",
      "description": "Stores user-specific settings and profile information.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The unique Firebase Auth ID." },
        "email": { "type": "string", "format": "email" },
        "streak": { "type": "number", "description": "Current daily streak." },
        "lastDate": { "type": "string", "description": "Last date a response was submitted (YYYY-MM-DD)." }
      },
      "required": ["uid", "email"]
    },
    "entries": {
      "title": "Chaos Entry",
      "description": "A creative response to a daily prompt.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Owner of the entry." },
        "date": { "type": "string", "description": "Date of the entry (YYYY-MM-DD)." },
        "prompt": { "type": "string" },
        "response": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "date", "prompt", "response"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "users",
      "description": "User profile document."
    },
    "/users/{userId}/entries/{entryId}": {
      "schema": "entries",
      "description": "Subcollection of chaos entries for a specific user."
    }
  }
}
